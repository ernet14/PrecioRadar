generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum AlertType {
  TARGET_PRICE
  PERCENTAGE_DROP
}

enum NotificationChannel {
  EMAIL
  INTERNAL
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
  UNKNOWN
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ApiTier {
  FREE
  PRO
  BUSINESS
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  email           String           @unique
  name            String?
  role            UserRole         @default(USER)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  alerts            Alert[]
  clickTracking     ClickTracking[]
  notifications     Notification[]
  productReports    ProductReport[]
  productReviews    ProductReview[]
  productVotes      ProductVote[]
  pushSubscriptions PushSubscription[]
  searchLogs        SearchLog[]
  trackedProducts   TrackedProduct[]
}

model Category {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @unique
  slug        String      @unique
  description String?
  active      Boolean     @default(true)
  featured    Boolean     @default(false)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  products    Product[]
  searchLogs  SearchLog[]
}

model Store {
  id               String          @id @default(uuid()) @db.Uuid
  name             String
  slug             String          @unique
  baseUrl          String
  logoUrl          String?
  isDemo           Boolean         @default(false)
  hasAffiliate     Boolean         @default(false)
  affiliateEnabled Boolean         @default(false)
  affiliateProgram String?         @default("mercadolibre")
  active           Boolean         @default(true)
  // Auto-bloqueo temporal del monitor (p. ej. 403 repetidos). Si blockedUntil
  // está en el futuro, el cron saltea esta tienda. Expira solo; no destructivo.
  blockedUntil     DateTime?
  blockReason      String?
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  affiliateLinks   AffiliateLink[]
  clickTracking    ClickTracking[]
  offers           ProductOffer[]
  priceHistory     PriceHistory[]
  providerLogs     ProviderLog[]

  @@index([active])
  @@index([isDemo])
}

model Product {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  slug            String           @unique
  brand           String?
  model           String?
  categoryId      String           @db.Uuid
  imageUrl        String?
  isDemo          Boolean          @default(false)
  normalizedName  String
  // Descripción SEO autogenerada por IA (Etapa 17). Cacheada; se regenera si
  // queda vieja. aiDescriptionAt marca cuándo se generó.
  aiDescription   String?
  aiDescriptionAt DateTime?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  category        Category                @relation(fields: [categoryId], references: [id])
  affiliateLinks  AffiliateLink[]
  alerts          Alert[]
  clickTracking   ClickTracking[]
  offers          ProductOffer[]
  priceHistory    PriceHistory[]
  productReports  ProductReport[]
  productReviews  ProductReview[]
  productVotes    ProductVote[]
  trackedProducts TrackedProduct[]
  weeklyFeatured  WeeklyFeaturedProduct[]

  @@index([categoryId])
  @@index([isDemo])
  @@index([normalizedName])
}

model ProductOffer {
  id             String           @id @default(uuid()) @db.Uuid
  productId      String           @db.Uuid
  storeId        String           @db.Uuid
  externalId     String?
  title          String
  price          Decimal          @db.Decimal(14, 2)
  currency       String           @default("ARS")
  productUrl     String
  affiliateUrl   String?
  imageUrl       String?
  available      Boolean          @default(true)
  condition      ProductCondition @default(UNKNOWN)
  isDemo         Boolean          @default(false)
  lastCheckedAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  product        Product          @relation(fields: [productId], references: [id])
  store          Store            @relation(fields: [storeId], references: [id])
  clickTracking  ClickTracking[]
  priceHistory   PriceHistory[]
  productReports ProductReport[]
  trackedProducts TrackedProduct[]

  @@unique([storeId, externalId])
  @@index([productId])
  @@index([storeId])
  @@index([available])
  @@index([isDemo])
  @@index([productId, storeId, available])
}

model PriceHistory {
  id         String        @id @default(uuid()) @db.Uuid
  productId  String        @db.Uuid
  storeId    String        @db.Uuid
  offerId    String?       @db.Uuid
  price      Decimal       @db.Decimal(14, 2)
  currency   String        @default("ARS")
  source     String
  isDemo     Boolean       @default(false)
  recordedAt DateTime      @default(now())

  product    Product       @relation(fields: [productId], references: [id])
  store      Store         @relation(fields: [storeId], references: [id])
  offer      ProductOffer? @relation(fields: [offerId], references: [id])

  @@index([productId, recordedAt])
  @@index([storeId, recordedAt])
  @@index([offerId, recordedAt])
  @@index([isDemo])
}

model ProductImportDraft {
  id                     String    @id @default(uuid()) @db.Uuid
  status                 String    @default("DRAFT")
  originalUrl            String
  normalizedUrl          String?
  sourceDomain           String?
  detectedStoreSlug      String?
  detectedStoreName      String?
  shortUrl               Boolean   @default(false)
  unexpandedShortUrl     Boolean   @default(false)
  suggestedSlug          String?
  suggestedTitle         String?
  suggestedCategorySlug  String?
  productName            String?
  storeSlug              String?
  storeName              String?
  categorySlug           String?
  currentPrice           Decimal?  @db.Decimal(14, 2)
  previousPrice          Decimal?  @db.Decimal(14, 2)
  imageUrl               String?
  externalUrl            String?
  affiliateUrl           String?
  shortDescription       String?
  fieldSources           Json?
  publishedProductId     String?   @db.Uuid
  publishedOfferId       String?   @db.Uuid
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
  @@index([storeSlug])
}

model TrackedProduct {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  offerId   String?  @db.Uuid
  createdAt DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id])
  product   Product       @relation(fields: [productId], references: [id])
  offer     ProductOffer? @relation(fields: [offerId], references: [id])

  @@index([productId])
  @@index([offerId])
  @@index([userId, offerId])
}

model Alert {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @db.Uuid
  productId           String              @db.Uuid
  alertType           AlertType
  targetPrice         Decimal?            @db.Decimal(14, 2)
  targetPercentage    Decimal?            @db.Decimal(5, 2)
  notificationChannel NotificationChannel
  active              Boolean             @default(true)
  paused              Boolean             @default(false)
  lastNotifiedAt      DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user                User                @relation(fields: [userId], references: [id])
  product             Product             @relation(fields: [productId], references: [id])

  @@index([userId, active])
  @@index([productId])
  @@index([lastNotifiedAt])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt])
}

model ClickTracking {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String?       @db.Uuid
  productId   String        @db.Uuid
  storeId     String        @db.Uuid
  offerId     String?       @db.Uuid
  url         String
  isAffiliate Boolean       @default(false)
  program     String?
  clickedAt   DateTime      @default(now())

  user        User?         @relation(fields: [userId], references: [id])
  product     Product       @relation(fields: [productId], references: [id])
  store       Store         @relation(fields: [storeId], references: [id])
  offer       ProductOffer? @relation(fields: [offerId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([storeId])
  @@index([clickedAt])
  @@index([isAffiliate])
  @@index([program])
}

model ProductReview {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  userId    String   @db.Uuid
  rating    Int      // 1..5
  body      String
  status    String   @default("APPROVED") // APPROVED | REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@index([productId, status])
}

model ProductVote {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  userId    String   @db.Uuid
  value     Int      // 1 = oferta real, -1 = no es real
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@index([productId])
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AffiliateLink {
  id           String   @id @default(uuid()) @db.Uuid
  storeId      String   @db.Uuid
  productId    String?  @db.Uuid
  originalUrl  String
  affiliateUrl String
  program      String?  @default("mercadolibre")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store        Store    @relation(fields: [storeId], references: [id])
  product      Product? @relation(fields: [productId], references: [id])

  @@index([storeId, active])
  @@index([productId])
}

model SearchLog {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String?   @db.Uuid
  query        String
  detectedType String
  categoryId   String?   @db.Uuid
  createdAt    DateTime  @default(now())

  user         User?     @relation(fields: [userId], references: [id])
  category     Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([query])
  @@index([createdAt])
}

model ProviderLog {
  id           String   @id @default(uuid()) @db.Uuid
  storeId      String?  @db.Uuid
  provider     String
  action       String
  status       String
  errorMessage String?
  latencyMs    Int?
  createdAt    DateTime @default(now())

  store        Store?   @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([provider, action])
  @@index([status])
  @@index([createdAt])
}

model ScrapeJob {
  id          String    @id @default(uuid()) @db.Uuid
  provider    String
  action      String
  status      String    @default("running")
  processed   Int       @default(0)
  updated     Int       @default(0)
  errors      Int       @default(0)
  outliers    Int       @default(0)
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  metadata    Json?

  @@index([provider, action, startedAt])
  @@index([status])
  @@index([startedAt])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actorEmail String?
  event      String
  resource   String?
  resourceId String?
  metadata   Json?
  ipHash     String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([event, createdAt])
  @@index([createdAt])
}

model MercadoLibreCache {
  id        String   @id @default(uuid()) @db.Uuid
  cacheKey  String   @unique
  endpoint  String
  body      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([endpoint])
  @@index([expiresAt])
}

model ProductReport {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @db.Uuid
  productId String?       @db.Uuid
  offerId   String?       @db.Uuid
  reason    String
  message   String?
  status    ReportStatus  @default(OPEN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User?         @relation(fields: [userId], references: [id])
  product   Product?      @relation(fields: [productId], references: [id])
  offer     ProductOffer? @relation(fields: [offerId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([offerId])
  @@index([status])
}

model NewsletterSubscription {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  confirmed   Boolean   @default(false)
  confirmToken String?  @unique
  source      String    @default("web")
  segments    String[]  @default([])
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([confirmed])
  @@index([createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  path      String?
  props     Json?
  userId    String?  @db.Uuid
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([createdAt])
}

model MercadoLibreAuth {
  id           String   @id @default(uuid()) @db.Uuid
  singletonKey String   @unique @default("default")
  mlUserId     String
  accessToken  String
  refreshToken String
  scope        String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Bitácora del bot de monitoreo: reportes diarios, chequeos periódicos y
// alertas críticas. dedupeKey + createdAt sirven para el anti-spam de alertas.
model SystemHealthLog {
  id              String   @id @default(uuid()) @db.Uuid
  reportType      String   // "daily" | "health-watch" | "exception"
  status          String   // "ok" | "warn" | "fail" | "critical"
  summary         String
  metrics         Json?
  detectedErrors  Json?
  actionsTaken    Json?
  recommendations String?
  dedupeKey       String?
  emailSent       Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([reportType, createdAt])
  @@index([dedupeKey, createdAt])
  @@index([createdAt])
}

model DataRadarSnapshot {
  id                  String   @id @default(uuid()) @db.Uuid
  source              String   @default("bna")
  scope               String
  categorySlug        String?
  snapshotDate        DateTime @db.Date
  generatedAt         DateTime @default(now())
  status              String
  priceBaseDate       DateTime? @db.Date
  priceLatestDate     DateTime? @db.Date
  priceDays           Int      @default(0)
  productsTracked     Int      @default(0)
  priceLatestIndex    Float?
  priceTotalChangePct Float?
  fxFromDate          DateTime? @db.Date
  fxToDate            DateTime? @db.Date
  fxRates             Int      @default(0)
  fxCarried           Int      @default(0)
  betaLag0            Float?
  correlationLag0     Float?
  payload             Json

  @@unique([source, scope, snapshotDate])
  @@index([source, snapshotDate])
  @@index([scope, snapshotDate])
  @@index([status, snapshotDate])
}

model BankPromo {
  id          String    @id @default(uuid()) @db.Uuid
  entity      String
  entitySlug  String
  dayOfWeek   Int[]
  discountPct Int
  promoType   String    @default("percentage")
  maxAmount   Int?
  storeSlug   String?
  categorySlug String?
  commerceChannel String @default("online")
  paymentType String    @default("cualquiera")
  installments Int?
  validFrom   DateTime  @default(now())
  validUntil  DateTime?
  sourceUrl   String?
  active      Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([entitySlug, active])
  @@index([storeSlug, active])
  @@index([categorySlug, active])
  @@index([active])
}

// Selección semanal de productos para la sección "Detectadas por PrecioRadar" en la home.
// Se genera cada lunes por cron. Campos de display denormalizados para no hacer joins al leer.
model WeeklyFeaturedProduct {
  id        String   @id @default(uuid()) @db.Uuid
  weekStart DateTime @db.Date
  slug      String
  productId String?  @db.Uuid
  rank      Int
  score     Float    @default(0)
  reason    String   @default("")
  isDemo    Boolean  @default(false)
  pinned    Boolean  @default(false)
  name      String   @default("")
  imageUrl  String?
  price     Decimal  @default(0) @db.Decimal(14, 2)
  storeName String   @default("")
  createdAt DateTime @default(now())

  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([weekStart, slug])
  @@index([weekStart, rank])
  @@map("WeeklyFeaturedProduct")
}

model BankPromoBotSource {
  id            String    @id @default(uuid()) @db.Uuid
  url           String    @unique
  active        Boolean   @default(true)
  lastCheckedAt DateTime?
  lastStatus    String?
  lastMessage   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([active, updatedAt])
}

// API pública pagada (Etapa 18, modelo Keepa-light). Cada clave tiene un tier
// que define rate limit diario y profundidad de historial accesible. Se guarda
// solo el hash SHA-256 de la clave (la clave en claro se muestra una vez al
// crearla). RLS deny-all: solo service_role la lee (la app usa service role).
model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  keyHash    String    @unique
  prefix     String
  tier       ApiTier   @default(FREE)
  ownerEmail String?
  active     Boolean   @default(true)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([active])
}
