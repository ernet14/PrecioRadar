generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum AlertType {
  TARGET_PRICE
  PERCENTAGE_DROP
}

enum NotificationChannel {
  EMAIL
  INTERNAL
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
  UNKNOWN
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  email           String           @unique
  name            String?
  role            UserRole         @default(USER)
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  alerts          Alert[]
  clickTracking   ClickTracking[]
  notifications   Notification[]
  productReports  ProductReport[]
  searchLogs      SearchLog[]
  trackedProducts TrackedProduct[]
}

model Category {
  id          String      @id @default(uuid()) @db.Uuid
  name        String      @unique
  slug        String      @unique
  description String?
  active      Boolean     @default(true)
  featured    Boolean     @default(false)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  products    Product[]
  searchLogs  SearchLog[]
}

model Store {
  id               String          @id @default(uuid()) @db.Uuid
  name             String
  slug             String          @unique
  baseUrl          String
  logoUrl          String?
  isDemo           Boolean         @default(false)
  hasAffiliate     Boolean         @default(false)
  affiliateEnabled Boolean         @default(false)
  active           Boolean         @default(true)
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  affiliateLinks   AffiliateLink[]
  clickTracking    ClickTracking[]
  offers           ProductOffer[]
  priceHistory     PriceHistory[]
  providerLogs     ProviderLog[]

  @@index([active])
  @@index([isDemo])
}

model Product {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  slug            String           @unique
  brand           String?
  model           String?
  categoryId      String           @db.Uuid
  imageUrl        String?
  isDemo          Boolean          @default(false)
  normalizedName  String
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  category        Category         @relation(fields: [categoryId], references: [id])
  affiliateLinks  AffiliateLink[]
  alerts          Alert[]
  clickTracking   ClickTracking[]
  offers          ProductOffer[]
  priceHistory    PriceHistory[]
  productReports  ProductReport[]
  trackedProducts TrackedProduct[]

  @@index([categoryId])
  @@index([isDemo])
  @@index([normalizedName])
}

model ProductOffer {
  id             String           @id @default(uuid()) @db.Uuid
  productId      String           @db.Uuid
  storeId        String           @db.Uuid
  externalId     String?
  title          String
  price          Decimal          @db.Decimal(14, 2)
  currency       String           @default("ARS")
  productUrl     String
  affiliateUrl   String?
  imageUrl       String?
  available      Boolean          @default(true)
  condition      ProductCondition @default(UNKNOWN)
  isDemo         Boolean          @default(false)
  lastCheckedAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  product        Product          @relation(fields: [productId], references: [id])
  store          Store            @relation(fields: [storeId], references: [id])
  clickTracking  ClickTracking[]
  priceHistory   PriceHistory[]
  productReports ProductReport[]
  trackedProducts TrackedProduct[]

  @@unique([storeId, externalId])
  @@index([productId])
  @@index([storeId])
  @@index([available])
  @@index([isDemo])
  @@index([productId, storeId, available])
}

model PriceHistory {
  id         String        @id @default(uuid()) @db.Uuid
  productId  String        @db.Uuid
  storeId    String        @db.Uuid
  offerId    String?       @db.Uuid
  price      Decimal       @db.Decimal(14, 2)
  currency   String        @default("ARS")
  source     String
  isDemo     Boolean       @default(false)
  recordedAt DateTime      @default(now())

  product    Product       @relation(fields: [productId], references: [id])
  store      Store         @relation(fields: [storeId], references: [id])
  offer      ProductOffer? @relation(fields: [offerId], references: [id])

  @@index([productId, recordedAt])
  @@index([storeId, recordedAt])
  @@index([offerId, recordedAt])
  @@index([isDemo])
}

model TrackedProduct {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.Uuid
  offerId   String?  @db.Uuid
  createdAt DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id])
  product   Product       @relation(fields: [productId], references: [id])
  offer     ProductOffer? @relation(fields: [offerId], references: [id])

  @@index([productId])
  @@index([offerId])
  @@index([userId, offerId])
}

model Alert {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @db.Uuid
  productId           String              @db.Uuid
  alertType           AlertType
  targetPrice         Decimal?            @db.Decimal(14, 2)
  targetPercentage    Decimal?            @db.Decimal(5, 2)
  notificationChannel NotificationChannel
  active              Boolean             @default(true)
  paused              Boolean             @default(false)
  lastNotifiedAt      DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user                User                @relation(fields: [userId], references: [id])
  product             Product             @relation(fields: [productId], references: [id])

  @@index([userId, active])
  @@index([productId])
  @@index([lastNotifiedAt])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt])
}

model ClickTracking {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String?       @db.Uuid
  productId   String        @db.Uuid
  storeId     String        @db.Uuid
  offerId     String?       @db.Uuid
  url         String
  isAffiliate Boolean       @default(false)
  clickedAt   DateTime      @default(now())

  user        User?         @relation(fields: [userId], references: [id])
  product     Product       @relation(fields: [productId], references: [id])
  store       Store         @relation(fields: [storeId], references: [id])
  offer       ProductOffer? @relation(fields: [offerId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([storeId])
  @@index([clickedAt])
  @@index([isAffiliate])
}

model AffiliateLink {
  id           String   @id @default(uuid()) @db.Uuid
  storeId      String   @db.Uuid
  productId    String?  @db.Uuid
  originalUrl  String
  affiliateUrl String
  program      String?  @default("mercadolibre")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store        Store    @relation(fields: [storeId], references: [id])
  product      Product? @relation(fields: [productId], references: [id])

  @@index([storeId, active])
  @@index([productId])
}

model SearchLog {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String?   @db.Uuid
  query        String
  detectedType String
  categoryId   String?   @db.Uuid
  createdAt    DateTime  @default(now())

  user         User?     @relation(fields: [userId], references: [id])
  category     Category? @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([query])
  @@index([createdAt])
}

model ProviderLog {
  id           String   @id @default(uuid()) @db.Uuid
  storeId      String?  @db.Uuid
  provider     String
  action       String
  status       String
  errorMessage String?
  latencyMs    Int?
  createdAt    DateTime @default(now())

  store        Store?   @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([provider, action])
  @@index([status])
  @@index([createdAt])
}

model ScrapeJob {
  id          String    @id @default(uuid()) @db.Uuid
  provider    String
  action      String
  status      String    @default("running")
  processed   Int       @default(0)
  updated     Int       @default(0)
  errors      Int       @default(0)
  outliers    Int       @default(0)
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  metadata    Json?

  @@index([provider, action, startedAt])
  @@index([status])
  @@index([startedAt])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actorEmail String?
  event      String
  resource   String?
  resourceId String?
  metadata   Json?
  ipHash     String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([event, createdAt])
  @@index([createdAt])
}

model MercadoLibreCache {
  id        String   @id @default(uuid()) @db.Uuid
  cacheKey  String   @unique
  endpoint  String
  body      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([endpoint])
  @@index([expiresAt])
}

model ProductReport {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @db.Uuid
  productId String?       @db.Uuid
  offerId   String?       @db.Uuid
  reason    String
  message   String?
  status    ReportStatus  @default(OPEN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User?         @relation(fields: [userId], references: [id])
  product   Product?      @relation(fields: [productId], references: [id])
  offer     ProductOffer? @relation(fields: [offerId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([offerId])
  @@index([status])
}

model NewsletterSubscription {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  confirmed   Boolean   @default(false)
  confirmToken String?  @unique
  source      String    @default("web")
  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([confirmed])
  @@index([createdAt])
}

model BankPromo {
  id          String    @id @default(uuid()) @db.Uuid
  entity      String
  entitySlug  String
  dayOfWeek   Int[]
  discountPct Int
  promoType   String    @default("percentage")
  maxAmount   Int?
  storeSlug   String?
  paymentType String    @default("cualquiera")
  validFrom   DateTime  @default(now())
  validUntil  DateTime?
  sourceUrl   String?
  active      Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([entitySlug, active])
  @@index([active])
}
