# Runtime: en Supabase usar el TRANSACTION pooler (puerto 6543, ?pgbouncer=true)
# para serverless. NO usar el session pooler (5432) en runtime: agota el límite
# de clientes ("max clients reached in session mode").
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/precioradar"
# Solo para migraciones (Prisma CLI). En Supabase: session pooler (5432) o la
# conexión directa db.<ref>.supabase.com:5432. No usar en runtime.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/precioradar"
# Conexiones del pool pg por instancia serverless (default 3). Subir con cuidado:
# el total entre instancias no debe superar el límite del pooler de Supabase.
DATABASE_POOL_MAX="3"

NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SUPABASE_SERVICE_ROLE_KEY=""

RESEND_API_KEY=""
RESEND_FROM_EMAIL="PrecioRadar <alertas@tu-dominio.com>"

CRON_SECRET=""

# MercadoLibre OAuth Authorization Code flow.
# Crear app en developers.mercadolibre.com.ar y configurar el redirect URI
# en su panel para que coincida exactamente con MERCADOLIBRE_REDIRECT_URI.
MERCADOLIBRE_CLIENT_ID=""
MERCADOLIBRE_CLIENT_SECRET=""
MERCADOLIBRE_REDIRECT_URI="https://www.precio-radar.com/api/auth/mercadolibre/callback"
# Opcional: token estatico para tests/dev. En prod se usa el flow OAuth
# y la tabla MercadoLibreAuth; dejar vacio.
MERCADOLIBRE_ACCESS_TOKEN=""
MERCADOLIBRE_SITE_ID="MLA"
MERCADOLIBRE_AFFILIATE_TAG=""
# Search de MeLi (/sites/MLA/search) bloqueado por permisos: 403 con token válido.
# Dejar en "false" (o vacío). Poner "true" SOLO cuando MeLi habilite el permiso;
# reactiva la búsqueda sin cambios de código. Ver docs/mercadolibre-permiso-busqueda.md
MERCADOLIBRE_SEARCH_ENABLED="false"

# Programas de afiliados adicionales (Etapa 14 — diversificación).
# Cada tienda define su programa con Store.affiliateProgram; el tag/ID sale de
# estas variables. Dejar vacío desactiva el auto-tagging de ese programa.
AMAZON_AFFILIATE_TAG=""
AWIN_AFFILIATE_ID=""
IMPACT_AFFILIATE_TAG=""
CJ_AFFILIATE_TAG=""
RAKUTEN_AFFILIATE_TAG=""
TEMU_AFFILIATE_TAG=""
SHEIN_AFFILIATE_TAG=""

# Web Push (Etapa 15). Generar con: npx web-push generate-vapid-keys
# La pública también va en NEXT_PUBLIC_VAPID_PUBLIC_KEY (se usa en el cliente).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:soporte@precio-radar.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Upstash Redis (rate limiting) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Sentry (error monitoring) — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Bot de monitoreo (Etapa 17). Destinatario del reporte diario y de las alertas
# críticas inmediatas. Requiere RESEND_API_KEY + RESEND_FROM_EMAIL configurados.
DAILY_REPORT_EMAIL=""
# Ventana anti-spam: no repetir la misma alerta crítica por estos minutos.
ALERT_DEDUP_WINDOW_MINUTES="180"
# Umbrales opcionales del monitor (tienen defaults razonables si se omiten):
# MONITOR_PROVIDER_403="5"        # 403 por proveedor en la ventana -> auto-bloqueo
# MONITOR_AUTO_BLOCK_HOURS="6"    # horas de bloqueo temporal de la tienda
# MONITOR_PRICES_STALE_HOURS="36" # alerta si no hay refresh de precios exitoso
